# Required: IPFS swarm key (generate with: tsipfs generate-swarm-key)
TSIPFS_SWARM_KEY=

# Data directory for pinned content, cache, and tsnet state
TSIPFS_DATA_DIR=./data

# Max disk usage for pinned content (0 = unlimited)
# Supports: TB, GB, MB, KB, or plain bytes
TSIPFS_PIN_MAX_SIZE=0

# Max disk usage for cached content from the swarm
TSIPFS_CACHE_MAX_SIZE=10GB

# Comma-separated bootstrap peer multiaddrs
TSIPFS_BOOTSTRAP_PEERS=

# Tailscale hostname (defaults to "tsipfs")
TSIPFS_FUNNEL_HOSTNAME=tsipfs

# Port for tailnet-only admin UI and REST API
TSIPFS_ADMIN_PORT=8080

# Tailscale auth key (for headless/container startup)
TS_AUTHKEY=
